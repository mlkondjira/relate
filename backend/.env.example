# ─── Base de données ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/relate_db"

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Serveur ───────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
CLIENT_URL="http://localhost:8081"

# ─── Chiffrement données de santé ──────────────────────────────
CYCLE_ENCRYPTION_KEY="32-char-hex-key-for-aes-256-gcm!!"

# ─── Expo Push Notifications ───────────────────────────────────
# Pas de clé requise pour les push Expo en mode dev
